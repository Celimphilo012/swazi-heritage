lici":3.0149030205422647,"plai":3.0149030205422647,"kei":3.0149030205422647,"establish":3.0149030205422647,"administr":3.0149030205422647,"siyilandela":3.0149030205422647,"inkhosi":3.0149030205422647,"march":3.0149030205422647,"call":3.0149030205422647,"power":2.6094379124341005,"uyawushisa":3.0149030205422647,"burn":3.0149030205422647,"veget":3.0149030205422647,"sea":3.0149030205422647,"symbolis":3.0149030205422647,"destruct":3.0149030205422647,"old":3.0149030205422647,"welcom":3.0149030205422647,"distanc":3.0149030205422647,"fire":3.0149030205422647,"wena":3.0149030205422647,"wendlovu":3.0149030205422647,"view":3.0149030205422647,"strength":3.0149030205422647,"great":3.0149030205422647,"eleph":3.0149030205422647,"symbol":3.0149030205422647,"digniti":3.0149030205422647,"tintfombi":3.0149030205422647,"tiyabingelela":3.0149030205422647,"open":3.0149030205422647,"approach":3.0149030205422647,"greet":3.0149030205422647,"announc":3.0149030205422647,"express":3.0149030205422647,"gratitud":3.0149030205422647,"bumnandzi":3.0149030205422647,"celebratori":3.0149030205422647,"after":3.0149030205422647,"sweet":3.0149030205422647},"documents":[{"type":"ceremony","data":{"id":1,"name":"Incwala — First Fruits Ceremony","description":"Incwala is the most sacred and important national ceremony of the Swazi people. It is a First Fruits ceremony that celebrates the kingship, the new harvest, and the renewal of the nation. No Swazi person may eat the new crops until the king has tasted them during Incwala. The ceremony takes place over several weeks and involves two main phases — Little Incwala and Big Incwala. During Big Incwala, warriors from across the kingdom gather at the royal cattle byre dressed in full traditional regalia. The king emerges and performs sacred rituals that strengthen his spiritual connection to the land and the ancestors. Songs are sung exclusively during this ceremony and are considered sacred. Foreigners and non-Swazi are not permitted to attend certain sacred parts of the ceremony. Incwala is a deeply spiritual event that connects the living king to past kings and to the future of the nation.","month_celebrated":"Incwala season (December–January)","immunology_notes":"Participants must observe a period of sexual abstinence before and during Incwala. Pregnant women and those who have recently given birth are restricted from certain areas of the ceremony. Warriors who have killed an animal or a person must undergo ritual cleansing before participation. The eating of certain foods including cucumbers and watery fruits is forbidden during the ceremony period as these are considered to weaken the spiritual potency of the ritual."},"vector":{"incwala":0.1276183148514391,"first":0.03137507891868,"fruit":0.042539438283813034,"ceremoni":0.0816662499332968,"season":0.01568753945934,"decemb":0.020370966355015303,"januari":0.020370966355015303,"most":0.01568753945934,"sacr":0.07052534898470542,"import":0.017631337246176354,"nation":0.0306248437249863,"swazi":0.028489157596787117,"peopl":0.01568753945934,"celebr":0.012947910350501048,"kingship":0.020370966355015303,"new":0.028359625522542023,"harvest":0.01568753945934,"renew":0.020370966355015303,"person":0.040741932710030605,"eat":0.040741932710030605,"crop":0.020370966355015303,"until":0.020370966355015303,"king":0.0408331249666484,"tast":0.01568753945934,"them":0.017631337246176354,"dure":0.0510414062083105,"take":0.020370966355015303,"place":0.020370966355015303,"over":0.017631337246176354,"sever":0.020370966355015303,"week":0.020370966355015303,"involv":0.020370966355015303,"two":0.017631337246176354,"main":0.020370966355015303,"phase":0.020370966355015303,"littl":0.020370966355015303,"big":0.040741932710030605,"warrior":0.03526267449235271,"across":0.017631337246176354,"kingdom":0.012947910350501048,"gather":0.01568753945934,"royal":0.0072229248073442665,"cattl":0.017631337246176354,"byre":0.017631337246176354,"dress":0.017631337246176354,"full":0.017631337246176354,"tradit":0.011004112563664691,"regalia":0.017631337246176354,"emerg":0.020370966355015303,"perform":0.020370966355015303,"ritual":0.05289401173852907,"strengthen":0.017631337246176354,"spiritu":0.04706261837802,"connect":0.03526267449235271,"land":0.014179812761271011,"ancestor":0.017631337246176354,"song":0.012947910350501048,"sung":0.011906351703019572,"exclus":0.020370966355015303,"consid":0.03137507891868,"foreign":0.017631337246176354,"non":0.020370966355015303,"not":0.01568753945934,"permit":0.020370966355015303,"attend":0.017631337246176354,"certain":0.05289401173852907,"part":0.01568753945934,"deepli":0.020370966355015303,"event":0.017631337246176354,"live":0.020370966355015303,"past":0.020370966355015303,"futur":0.020370966355015303,"particip":0.028359625522542023,"must":0.03526267449235271,"observ":0.020370966355015303,"period":0.028359625522542023,"sexual":0.020370966355015303,"abstin":0.020370966355015303,"befor":0.025895820701002097,"pregnant":0.017631337246176354,"women":0.012947910350501048,"who":0.025895820701002097,"recent":0.020370966355015303,"given":0.017631337246176354,"birth":0.017631337246176354,"restrict":0.020370966355015303,"area":0.017631337246176354,"kill":0.020370966355015303,"anim":0.020370966355015303,"undergo":0.020370966355015303,"cleans":0.020370966355015303,"food":0.020370966355015303,"includ":0.017631337246176354,"cucumb":0.020370966355015303,"wateri":0.020370966355015303,"forbidden":0.020370966355015303,"weaken":0.020370966355015303,"potenc":0.020370966355015303}},{"type":"ceremony","data":{"id":2,"name":"Umhlanga — Reed Dance Ceremony","description":"Umhlanga is one of the most celebrated and visually striking ceremonies in Eswatini. Thousands of unmarried Swazi girls and young women travel from all parts of the kingdom to cut reeds from riverbeds and carry them to the Queen Mother's royal residence at Ludzidzini. The reeds are used to repair and reinforce the windbreak surrounding the Queen Mother's village. The ceremony celebrates the purity and unity of young women, honours the Queen Mother, and serves as a time of social gathering. On the final day the maidens dress in full traditional regalia and dance before the king and thousands of spectators from around the world. Umhlanga has become one of Eswatini's most internationally recognised cultural events and attracts visitors from many countries. It is also an occasion where the king may choose a new wife from among the participants.","month_celebrated":"Umhlanga season (August–September)","immunology_notes":"Only unmarried girls and young women who have not given birth may participate as reed dancers. Participants who are menstruating are traditionally excused from certain parts of the procession. The long journey on foot to cut reeds requires participants to be physically fit. Girls are advised to wear appropriate footwear during the reed-cutting journey to prevent cuts and injuries in the riverbed. Traditional healers are present throughout the ceremony to attend to any participant who becomes unwell."},"vector":{"umhlanga":0.05710509629028869,"reed":0.1065076698952694,"danc":0.031588514829691425,"ceremoni":0.04111090132696573,"season":0.015794257414845712,"august":0.02050954435743037,"septemb":0.017751278315878236,"on":0.03550255663175647,"most":0.031588514829691425,"celebr":0.026071982746587143,"visual":0.02050954435743037,"strike":0.02050954435743037,"eswatini":0.028552548145144345,"thousand":0.03550255663175647,"unmarri":0.04101908871486074,"swazi":0.009560987129987512,"girl":0.06152863307229111,"young":0.06152863307229111,"women":0.03910797411988071,"travel":0.015794257414845712,"all":0.017751278315878236,"part":0.031588514829691425,"kingdom":0.013035991373293572,"cut":0.08203817742972148,"riverb":0.04101908871486074,"carri":0.014276274072572172,"them":0.017751278315878236,"queen":0.06152863307229111,"mother":0.06152863307229111,"royal":0.00727206035025137,"resid":0.017751278315878236,"ludzidzini":0.017751278315878236,"us":0.0177512783158