.020650020688645646,"ensur":0.017872862413932194,"spoil":0.020650020688645646,"befor":0.013125278985439418,"unwel":0.017872862413932194,"encourag":0.020650020688645646,"rest":0.020650020688645646,"rather":0.020650020688645646,"than":0.020650020688645646,"undertak":0.020650020688645646,"long":0.017872862413932194,"journei":0.017872862413932194,"itself":0.020650020688645646,"rich":0.020650020688645646,"vitamin":0.020650020688645646,"consid":0.015902437260152873,"nutrit":0.020650020688645646,"medicin":0.020650020688645646,"knowledg":0.020650020688645646}},{"type":"lineage","data":{"id":1,"title":"The Dlamini Royal Lineage","description":"The Dlamini clan is the royal clan of the Swazi nation and has been the ruling family of the Kingdom of Eswatini for centuries. The lineage traces back to Ngwane III, who led the Swazi people to settle in the present-day territory of Eswatini in the mid-18th century. Sobhuza I, also known as Somhlolo, consolidated the kingdom and is remembered for his famous vision of people of different races arriving in the land. The Dlamini lineage is central to Swazi identity, governance, and cultural ceremonies including the Incwala and Umhlanga.","era":"Pre-colonial era (before 1840)"},"vector":{"1840":0.04277767069564099,"dlamini":0.12833301208692297,"royal":0.035048946606129554,"lineag":0.0866626255105031,"pre":0.04942463968102073,"coloni":0.03440348014210016,"era":0.0314146021618714,"befor":0.0314146021618714,"clan":0.0628292043237428,"swazi":0.06912123482499169,"nation":0.024767633176491652,"rule":0.038061571147251144,"famili":0.04277767069564099,"kingdom":0.0628292043237428,"eswatini":0.06880696028420032,"centuri":0.09884927936204146,"trace":0.04942463968102073,"back":0.04942463968102073,"ngwane":0.04942463968102073,"iii":0.04277767069564099,"who":0.0314146021618714,"led":0.03440348014210016,"peopl":0.07612314229450229,"settl":0.04942463968102073,"present":0.03440348014210016,"dai":0.04277767069564099,"territori":0.04277767069564099,"mid":0.04942463968102073,"18th":0.04942463968102073,"sobhuza":0.0314146021618714,"also":0.03440348014210016,"known":0.04277767069564099,"somhlolo":0.04942463968102073,"consolid":0.04942463968102073,"rememb":0.04942463968102073,"famou":0.04942463968102073,"vision":0.04942463968102073,"differ":0.04277767069564099,"race":0.04942463968102073,"arriv":0.04277767069564099,"land":0.03440348014210016,"central":0.04942463968102073,"ident":0.04277767069564099,"govern":0.03440348014210016,"cultur":0.0314146021618714,"ceremoni":0.024767633176491652,"includ":0.04277767069564099,"incwala":0.03440348014210016,"umhlanga":0.03440348014210016}},{"type":"lineage","data":{"id":2,"title":"The Sobhuza II Resistance Lineage","description":"This lineage documents the royal resistance led by King Sobhuza II against British colonial rule during the protectorate period. Sobhuza II ascended to the throne in 1921 and spent decades negotiating and fighting for Swazi land rights and sovereignty. He travelled to England to petition the British government regarding the land partition that had stripped the Swazi nation of two thirds of its territory. His persistence and diplomatic leadership preserved Swazi culture, traditions, and identity during one of the most difficult periods in the nation's history. The lineage connected to this era carries the burden and honour of having protected the kingdom through foreign occupation.","era":"Colonial period (1840–1968)"},"vector":{"1840":0.03526267449235271,"1921":0.040741932710030605,"1968":0.028359625522542023,"sobhuza":0.0776874621030063,"resist":0.07052534898470542,"lineag":0.07143811021811744,"coloni":0.056719251045084046,"period":0.08507887656762607,"document":0.03526267449235271,"royal":0.014445849614688533,"led":0.028359625522542023,"king":0.0204165624833242,"against":0.040741932710030605,"british":0.08148386542006121,"rule":0.03137507891868,"dure":0.0408331249666484,"protector":0.040741932710030605,"ascend":0.040741932710030605,"throne":0.040741932710030605,"spent":0.040741932710030605,"decad":0.040741932710030605,"negoti":0.040741932710030605,"fight":0.040741932710030605,"swazi":0.056978315193574235,"land":0.056719251045084046,"right":0.040741932710030605,"sovereignti":0.040741932710030605,"travel":0.03137507891868,"england":0.040741932710030605,"petit":0.040741932710030605,"govern":0.028359625522542023,"regard":0.03526267449235271,"partit":0.040741932710030605,"strip":0.040741932710030605,"nation":0.0408331249666484,"two":0.03526267449235271,"third":0.040741932710030605,"territori":0.03526267449235271,"persist":0.040741932710030605,"diplomat":0.03526267449235271,"leadership":0.03526267449235271,"preserv":0.03526267449235271,"cultur":0.025895820701002097,"tradit":0.022008225127329382,"ident":0.03526267449235271,"on":0.03526267449235271,"most":0.03137507891868,"difficult":0.040741932710030605,"histori":0.03526267449235271,"connect":0.03526267449235271,"era":0.025895820701002097,"carri":0.028359625522542023,"burden":0.040741932710030605,"honour":0.03526267449235271,"have":0.040741932710030605,"protect":0.040741932710030605,"kingdom":0.025895820701002097,"through":0.03137507891868,"foreign":0.03526267449235271,"occup":0.040741932710030605}},{"type":"lineage","data":{"id":3,"title":"The Independence and Nation Building Lineage","description":"Following independence on 6 September 1968, Sobhuza II led Eswatini into a new era of self-governance. In 1973 he suspended the constitution and in 1978 introduced the Tinkhundla system of governance rooted in traditional Swazi political structures. This lineage documents the clans and royal figures who shaped the post-independence nation, built national institutions, and maintained the balance between modern governance and Swazi traditional law and custom. The period also saw the passing of Sobhuza II in 1982 and the eventual coronation of King Mswati III in 1986, who continues to reign today.","era":"Post-independence (1968–present)"},"vector":{"1968":0.059115839117411535,"1973"